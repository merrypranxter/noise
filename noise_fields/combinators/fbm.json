{
  "id": "fbm",
  "display_name": "Fractal Brownian Motion Combinator",
  "description": "Sums multiple octaves of a base noise with increasing frequency (lacunarity) and decreasing amplitude (gain) to build fractal detail.",
  "accepts_base_noise": ["perlin", "simplex", "worley"],
  "parameters": {
    "octaves": { "type": "int", "min": 1, "max": 16, "typical": [4, 6] },
    "base_frequency": { "type": "float", "min": 0.1, "max": 20.0 },
    "lacunarity": { "type": "float", "min": 1.0, "max": 4.0, "typical": [2.0] },
    "gain": { "type": "float", "min": 0.0, "max": 1.0, "typical": [0.5] }
  },
  "shader_chunks": {
    "glsl": "shaders/glsl/fbm.glsl",
    "wgsl": "shaders/wgsl/fbm.wgsl"
  }
}
